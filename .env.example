# NoneBot2 监听地址
# 一般和你现有 OneBot / NapCat 反向连接配置保持一致
HOST=127.0.0.1
PORT=8080

# TS3 语音服务器地址
# 示例使用本地回环地址，实际可替换为你自己的公网域名或 IP
TS3_TRACKER__SERVER_HOST=127.0.0.1

# TS3 语音端口，默认通常为 9987
TS3_TRACKER__SERVER_PORT=9987

# TS3 ServerQuery 端口，默认通常为 10011
TS3_TRACKER__SERVERQUERY_PORT=10011

# TS3 ServerQuery 登录账号
# 示例请改成你自己的查询账号
TS3_TRACKER__SERVERQUERY_USERNAME=your-serverquery-username

# TS3 ServerQuery 登录密码
TS3_TRACKER__SERVERQUERY_PASSWORD=your-password

# 是否输出调试日志
# true = 输出更多调试信息
# false = 使用正常日志
TS3_TRACKER__DEBUG=false

# 是否必须使用命令前缀
# true = 需要 /上号 /ts /tsinfo 才会触发
# false = 也支持直接发送 上号 ts tsinfo
TS3_TRACKER__COMMAND_PREFIX_REQUIRED=true

# 单次查询超时时间，单位秒
TS3_TRACKER__QUERY_TIMEOUT_SECONDS=10

# 是否开启 TS3 进服 / 退服通知
# true = 开启通知
# false = 仅保留查询功能
TS3_TRACKER__NOTIFICATION_ENABLED=true

# 接收通知的群号
# 支持逗号、分号或换行分隔多个群号
TS3_TRACKER__NOTIFY_TARGET_GROUPS=100000000

# 接收通知的私聊 QQ
# 不需要可留空
TS3_TRACKER__NOTIFY_TARGET_USERS=

# 是否开启群白名单模式
# true = 只有白名单群可用群聊查询，且只有白名单群会收到群通知
# false = 所有群聊都可以查询
TS3_TRACKER__GROUP_WHITELIST_ENABLED=false

# 群白名单列表
# 支持逗号、分号或换行分隔多个群号
TS3_TRACKER__GROUP_WHITELIST_GROUPS=100000000

# TS3 在线状态轮询间隔，单位秒
# 当前项目默认建议为 5 秒
TS3_TRACKER__POLL_INTERVAL_SECONDS=5

# 启动时是否静默同步快照
# true = 启动时不同步历史进退服消息，只建立当前在线快照
# false = 启动后立即根据差异发送通知
TS3_TRACKER__STARTUP_SILENT=true

# 插件快照数据目录（可选）
# 不填写时使用 nonebot-plugin-localstore 提供的插件数据目录
# TS3_TRACKER__DATA_DIR=

# 是否开启指定频道录音（需要 ts3-recorder-sidecar 二进制）
TS3_TRACKER__RECORDING_ENABLED=false

# 监控频道：频道 ID 或名称，逗号/分号/换行分隔
TS3_TRACKER__RECORDING_CHANNELS=5,Lobby

# 录音 identity：绝对路径、相对 identities/ 的文件名，或 inline 字符串
# 留空则自动加载 config 目录下 nonebot_plugin_ts3_tracker/identities/ 内全部文件
# TS3_TRACKER__RECORDING_IDENTITIES=rec1.txt

# 录音输出根目录，留空则使用插件 data 目录下 recordings/
# 内部布局：{根}/{YYYY-MM-DD}/{channel_id}_{channel_name}/{HHMMSS}.wav
# TS3_TRACKER__RECORDING_OUTPUT_DIR=

# 切片默认写入插件 data 目录下 slices/，布局与录音相同（文件名含 _slice_{minutes}m）

# sidecar 二进制路径，留空则自动探测 recorder_sidecar/bin/<platform>/ts3-recorder-sidecar
# TS3_TRACKER__RECORDING_SIDECAR_PATH=

# TS 服务器/频道密码（无则留空）
TS3_TRACKER__RECORDING_SERVER_PASSWORD=
TS3_TRACKER__RECORDING_CHANNEL_PASSWORD=

# 录音 bot 昵称前缀
TS3_TRACKER__RECORDING_NICKNAME_PREFIX=RecBot

# 低于该秒数的录音会被丢弃
TS3_TRACKER__RECORDING_MIN_SESSION_SECONDS=5

# 至少多少真人（不含 RecBot）才开始录音，默认 2
TS3_TRACKER__RECORDING_MIN_HUMAN_COUNT=2

# 真人不足阈值后，延迟多少秒再结束录音；期间若人数恢复则继续录
TS3_TRACKER__RECORDING_STOP_GRACE_SECONDS=300

# /ts 切片 默认截取分钟数（未指定分钟参数时使用）
TS3_TRACKER__RECORDING_SLICE_DEFAULT_MINUTES=5
